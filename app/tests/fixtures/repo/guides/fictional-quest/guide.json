      "id": "fictional-quest:c1",
      "title": "Chapter 1 — The Castle Gate",
      "order": 0,
      "steps": [
        {
          "id": "fictional-quest:c1:s1",
          "order": 0,
          "text": "Talk to the gatekeeper twice; he hands over the rusty lantern you need for the cellar.",
          "location": "Castle Gate",
          "sourceRefs": ["src-wiki"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c1:s2",
          "order": 1,
          "text": "Pry the Old Coin from behind the loose brick left of the portcullis.",
          "location": "Castle Gate",
          "missable": {
            "deadline": "Before opening the gate — the courtyard locks behind you"
          },
          "sourceRefs": ["src-wiki", "src-manual"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c1:s3",
          "order": 2,
          "text": "Beat the Sentry Captain on the wall. Jump his lance sweep, counter the second thrust.",
          "location": "Castle Wall",
          "achievementRefs": [101],
          "images": [
            {
              "src": "images/castle-gate.png",
              "alt": "Castle gate and wall route",
              "caption": "The wall route to the Sentry Captain",
              "credit": "Fictional Quest wiki"
            }
          ],
          "sourceRefs": ["src-wiki", "src-ra"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c1:s4",
          "order": 3,
          "text": "Sweep the courtyard for blue coins — eight are reachable now; the rest need the Tide badge.",
          "location": "Courtyard",
          "sourceRefs": ["src-wiki"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c1:s5",
          "order": 4,
          "text": "Take the east stairs down to the docks and ring the bell to call the ferry.",
          "location": "Docks",
          "sourceRefs": ["src-manual"],
          "confidence": "normal"
        }
      ]
    },
    {
      "id": "fictional-quest:c2",
      "title": "Chapter 2 — The Sunken Vault",
      "order": 1,
      "steps": [
        {
          "id": "fictional-quest:c2:s1",
          "order": 0,
          "text": "Dive at the buoy and swim through the cracked grate into the vault antechamber.",
          "location": "Sunken Vault",
          "images": [
            {
              "src": "images/vault-entrance.png",
              "alt": "Vault entrance under the buoy"
            }
          ],
          "sourceRefs": ["src-wiki"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c2:s2",
          "order": 1,
          "text": "Pull the levers west, east, then center to drain the hall. Some sources list east first.",
          "location": "Sunken Vault",
          "sourceRefs": ["src-wiki", "src-manual"],
          "confidence": "flagged"
        },
        {
          "id": "fictional-quest:c2:s3",
          "order": 2,
          "text": "Feed the moray eel a mushroom so it leaves the east alcove.",
          "location": "Sunken Vault",
          "missable": {
            "deadline": "Before draining the vault — the eel flees once the water drops"
          },
          "sourceRefs": ["src-wiki"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c2:s4",
          "order": 3,
          "text": "Stock up at the diver's cache and check your prep card before the sealed door.",
          "location": "Vault Antechamber",
          "sourceRefs": ["src-manual"],
          "confidence": "normal"
        },
        {
          "id": "fictional-quest:c2:s5",
          "order": 4,
          "text": "Defeat the Vault Warden. Stay off the center tiles during the flood phase.",
          "location": "Vault Heart",
          "achievementRefs": [102],
          "sourceRefs": ["src-wiki", "src-ra"],
          "confidence": "normal"
        }
      ]
    }
